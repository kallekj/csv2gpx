# Copy this file to voxcpm.env and adjust values for your environment.
# Usage:
#   docker run --rm -p 10200:10200 --env-file voxcpm.env ghcr.io/<owner>/voxcpm-wyomming:latest

# Required: local model path inside container OR HuggingFace repo id.
# If using a local path, also mount it with -v /host/model/path:/models/VoxCPM:ro
VOXCPM_MODEL=OpenBMB/VoxCPM

# Network
VOXCPM_HOST=0.0.0.0
VOXCPM_PORT=10200

# GPU selection (comma-separated device indexes)
VOXCPM_DEVICES=0

# Inference tuning
VOXCPM_MAX_NUM_BATCHED_TOKENS=8192
VOXCPM_MAX_NUM_SEQS=16
VOXCPM_GPU_MEMORY_UTILIZATION=0.95
VOXCPM_INFERENCE_TIMESTEPS=10

# Service metadata
VOXCPM_SERVICE_NAME=voxcpm
VOXCPM_SERVICE_DESCRIPTION=VoxCPM_Wyoming_TTS_service
VOXCPM_SERVICE_VERSION=

# Voice metadata
VOXCPM_VOICE_NAME=default
VOXCPM_VOICE_LANGUAGE=en
VOXCPM_VOICE_SPEAKER=
VOXCPM_VOICE_DESCRIPTION=Default_VoxCPM_voice
VOXCPM_VOICE_VERSION=

# Attribution
VOXCPM_ATTRIBUTION_NAME=VoxCPM
VOXCPM_ATTRIBUTION_URL=https://github.com/OpenBMB/VoxCPM

# Logging
VOXCPM_LOG_LEVEL=INFO